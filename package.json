{
  "name": "nexus-profiling",
  "version": "0.1.0",
  "private": true,
  "description": "NexusProfiling - aplicação local de investigação OSINT legal e autorizada.",
  "type": "module",
  "scripts": {
    "dev": "concurrently -n api,web -c cyan,magenta \"npm:dev:api\" \"npm:dev:web\"",
    "dev:api": "tsx watch src/server/index.ts",
    "dev:web": "vite --host 127.0.0.1",
    "build": "tsc -p tsconfig.server.json && vite build",
    "preview": "vite preview --host 127.0.0.1",
    "test": "vitest run",
    "lint": "tsc --noEmit"
  },
  "dependencies": {
    "@vitejs/plugin-react": "^5.0.0",
    "concurrently": "^9.1.2",
    "cors": "^2.8.5",
    "cytoscape": "^3.31.1",
    "express": "^5.1.0",
    "helmet": "^8.1.0",
    "leaflet": "^1.9.4",
    "lucide-react": "^0.468.0",
    "pino": "^9.5.0",
    "pino-pretty": "^13.0.0",
    "react": "^19.0.0",
    "react-cytoscapejs": "^2.0.0",
    "react-dom": "^19.0.0",
    "react-leaflet": "^5.0.0",
    "sql.js": "^1.12.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/leaflet": "^1.9.16",
    "@types/node": "^22.10.2",
    "@types/react": "^19.0.1",
    "@types/react-cytoscapejs": "^1.2.5",
    "@types/react-dom": "^19.0.2",
    "@types/sql.js": "^1.4.9",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vite": "^6.0.5",
    "vitest": "^2.1.8"
  },
  "engines": {
    "node": ">=20"
  }
}
