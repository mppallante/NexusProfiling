{
  "name": "nexus-profiling",
  "version": "0.1.1",
  "private": true,
  "description": "NexusProfiling - aplicação local de investigação OSINT legal e autorizada.",
  "author": "mppallante",
  "type": "module",
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "npm run build:electron && concurrently -k -n api,web,electron -c cyan,magenta,green \"npm:dev:api\" \"npm:dev:web\" \"npm:dev:electron\"",
    "dev:api": "tsx watch src/server/index.ts",
    "dev:electron": "wait-on http://127.0.0.1:3333/api/health http://127.0.0.1:5173 && electron .",
    "dev:web": "vite --host 127.0.0.1",
    "build": "npm run build:server && npm run build:electron && vite build",
    "build:server": "tsc -p tsconfig.server.json --noEmit && esbuild src/server/app.ts src/server/index.ts --bundle --platform=node --target=node20 --format=esm --outdir=dist-server/server --external:express --external:cors --external:helmet --external:zod --external:sql.js --external:pino",
    "build:electron": "tsc -p tsconfig.electron.json",
    "pack:win": "npm run build && electron-builder --win dir",
    "dist:win": "npm run build && electron-builder --win nsis",
    "package:win": "npm run dist:win",
    "preview": "vite preview --host 127.0.0.1",
    "test": "vitest run",
    "lint": "tsc --noEmit"
  },
  "build": {
    "appId": "br.com.nexusprofiling.app",
    "productName": "NexusProfiling",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**",
      "dist-server/**",
      "dist-electron/**",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "node_modules/sql.js/dist/sql-wasm.wasm",
        "to": "sql-wasm.wasm"
      }
    ],
    "asarUnpack": [
      "node_modules/sql.js/dist/sql-wasm.wasm"
    ],
    "win": {
      "target": [
        "nsis"
      ],
      "artifactName": "NexusProfiling-Setup-${version}.${ext}",
      "signAndEditExecutable": false
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    }
  },
  "dependencies": {
    "@vitejs/plugin-react": "^5.0.0",
    "concurrently": "^9.1.2",
    "cors": "^2.8.5",
    "cytoscape": "^3.31.1",
    "express": "^5.1.0",
    "helmet": "^8.1.0",
    "leaflet": "^1.9.4",
    "lucide-react": "^0.468.0",
    "pino": "^9.5.0",
    "pino-pretty": "^13.0.0",
    "react": "^19.0.0",
    "react-cytoscapejs": "^2.0.0",
    "react-dom": "^19.0.0",
    "react-leaflet": "^5.0.0",
    "sql.js": "^1.12.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/leaflet": "^1.9.16",
    "@types/node": "^22.10.2",
    "@types/react": "^19.0.1",
    "@types/react-cytoscapejs": "^1.2.5",
    "@types/react-dom": "^19.0.2",
    "@types/sql.js": "^1.4.9",
    "electron": "^33.3.1",
    "electron-builder": "^25.1.8",
    "esbuild": "^0.24.2",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vite": "^6.0.5",
    "vitest": "^2.1.8",
    "wait-on": "^8.0.1"
  },
  "engines": {
    "node": ">=20"
  }
}
